<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.yy.mapper.YyProductFusionGroupMapper">
    
    <resultMap type="YyProductFusionGroup" id="YyProductFusionGroupResult">
        <result property="id"                column="id"                    />
        <result property="fusionKey"         column="fusion_key"            />
        <result property="commonName"        column="common_name"           />
        <result property="specification"     column="specification"         />
        <result property="manufacturer"      column="manufacturer"          />
        <result property="approvalNumber"    column="approval_number"       />
        <result property="platformCount"     column="platform_count"        />
        <result property="minPrice"          column="min_price"             />
        <result property="minPricePlatformId" column="min_price_platform_id" />
        <result property="totalStock"        column="total_stock"           />
        <result property="status"            column="status"                />
        <result property="lastUpdated"       column="last_updated"          />
    </resultMap>

    <sql id="selectYyProductFusionGroupVo">
        select id, fusion_key, common_name, specification, manufacturer,
               approval_number, platform_count, min_price, min_price_platform_id,
               total_stock, status, last_updated
        from yy_product_fusion_group
    </sql>

    <select id="selectYyProductFusionGroupList" parameterType="YyProductFusionGroup" resultMap="YyProductFusionGroupResult">
        <include refid="selectYyProductFusionGroupVo"/>
        <where>
            <if test="commonName != null and commonName != ''"> and common_name like concat('%', #{commonName}, '%')</if>
            <if test="manufacturer != null and manufacturer != ''"> and manufacturer like concat('%', #{manufacturer}, '%')</if>
            <if test="approvalNumber != null and approvalNumber != ''"> and approval_number like concat('%', #{approvalNumber}, '%')</if>
            <if test="status != null"> and status = #{status}</if>
        </where>
        order by min_price asc, id desc
    </select>
    
    <select id="selectYyProductFusionGroupById" parameterType="Long" resultMap="YyProductFusionGroupResult">
        <include refid="selectYyProductFusionGroupVo"/>
        where id = #{id}
    </select>

    <select id="selectByFusionKey" parameterType="String" resultMap="YyProductFusionGroupResult">
        <include refid="selectYyProductFusionGroupVo"/>
        where fusion_key = #{fusionKey}
    </select>

    <insert id="insertYyProductFusionGroup" parameterType="YyProductFusionGroup" useGeneratedKeys="true" keyProperty="id">
        insert into yy_product_fusion_group
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="fusionKey != null and fusionKey != ''">fusion_key,</if>
            <if test="commonName != null and commonName != ''">common_name,</if>
            <if test="specification != null and specification != ''">specification,</if>
            <if test="manufacturer != null and manufacturer != ''">manufacturer,</if>
            <if test="approvalNumber != null and approvalNumber != ''">approval_number,</if>
            <if test="platformCount != null">platform_count,</if>
            <if test="minPrice != null">min_price,</if>
            <if test="minPricePlatformId != null">min_price_platform_id,</if>
            <if test="totalStock != null">total_stock,</if>
            <if test="status != null">status,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="fusionKey != null and fusionKey != ''">#{fusionKey},</if>
            <if test="commonName != null and commonName != ''">#{commonName},</if>
            <if test="specification != null and specification != ''">#{specification},</if>
            <if test="manufacturer != null and manufacturer != ''">#{manufacturer},</if>
            <if test="approvalNumber != null and approvalNumber != ''">#{approvalNumber},</if>
            <if test="platformCount != null">#{platformCount},</if>
            <if test="minPrice != null">#{minPrice},</if>
            <if test="minPricePlatformId != null">#{minPricePlatformId},</if>
            <if test="totalStock != null">#{totalStock},</if>
            <if test="status != null">#{status},</if>
         </trim>
    </insert>

    <update id="updateYyProductFusionGroup" parameterType="YyProductFusionGroup">
        update yy_product_fusion_group
        <trim prefix="SET" suffixOverrides=",">
            <if test="commonName != null and commonName != ''">common_name = #{commonName},</if>
            <if test="specification != null and specification != ''">specification = #{specification},</if>
            <if test="manufacturer != null and manufacturer != ''">manufacturer = #{manufacturer},</if>
            <if test="approvalNumber != null">approval_number = #{approvalNumber},</if>
            <if test="platformCount != null">platform_count = #{platformCount},</if>
            <if test="minPrice != null">min_price = #{minPrice},</if>
            <if test="minPricePlatformId != null">min_price_platform_id = #{minPricePlatformId},</if>
            <if test="totalStock != null">total_stock = #{totalStock},</if>
            <if test="status != null">status = #{status},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteYyProductFusionGroupById" parameterType="Long">
        delete from yy_product_fusion_group where id = #{id}
    </delete>

    <delete id="deleteYyProductFusionGroupByIds" parameterType="Long">
        delete from yy_product_fusion_group where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
