    </update>

    <delete id="deleteYyPlatformApiByApiId" parameterType="Long">
        delete from yy_platform_api where api_id = #{apiId}
    </delete>

    <delete id="deleteYyPlatformApiByApiIds" parameterType="Long">
        delete from yy_platform_api where api_id in 
        <foreach item="apiId" collection="array" open="(" separator="," close=")">
            #{apiId}
        </foreach>
    </delete>

    <select id="selectApisByPlatformId" parameterType="Long" resultMap="YyPlatformApiResult">
        <include refid="selectYyPlatformApiVo"/>
        where platform_id = #{platformId} and is_active = 1
        order by sort_order desc, api_id asc
    </select>
</mapper>
