<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.yy.mapper.YyReferralRewardMapper">
    
    <resultMap type="YyReferralReward" id="YyReferralRewardResult">
        <result property="id"              column="id"                 />
        <result property="referrerId"      column="referrer_id"        />
        <result property="referredId"      column="referred_id"        />
        <result property="referralDepth"   column="referral_depth"     />
        <result property="triggerType"     column="trigger_type"       />
        <result property="triggerAmount"   column="trigger_amount"     />
        <result property="rewardAmount"    column="reward_amount"      />
        <result property="calculatedBy"    column="calculated_by"      />
        <result property="status"          column="status"             />
        <result property="configId"        column="config_id"          />
        <result property="payOrderId"      column="pay_order_id"       />
        <result property="remark"          column="remark"             />
        <result property="createTime"      column="create_time"        />
        <result property="updateTime"      column="update_time"        />
        <!-- 关联查询字段 -->
        <result property="referrerPhone"   column="referrer_phone"     />
        <result property="referredPhone"   column="referred_phone"     />
    </resultMap>

    <sql id="selectYyReferralRewardListVo">
        select rr.id, rr.referrer_id, rr.referred_id, rr.referral_depth, rr.trigger_type,
               rr.trigger_amount, rr.reward_amount, rr.calculated_by, rr.status,
               rr.config_id, rr.pay_order_id, rr.remark, rr.create_time, rr.update_time,
               u1.phone as referrer_phone, u2.phone as referred_phone
        from yy_referral_reward rr
        left join yy_user u1 on u1.user_id = rr.referrer_id
        left join yy_user u2 on u2.user_id = rr.referred_id
    </sql>

    <select id="selectYyReferralRewardList" parameterType="YyReferralReward" resultMap="YyReferralRewardResult">
        <include refid="selectYyReferralRewardListVo"/>
        <where>
            <if test="referrerId != null"> and rr.referrer_id = #{referrerId}</if>
            <if test="referredId != null"> and rr.referred_id = #{referredId}</if>
            <if test="status != null"> and rr.status = #{status}</if>
            <if test="referralDepth != null"> and rr.referral_depth = #{referralDepth}</if>
        </where>
        order by rr.create_time desc
    </select>

    <select id="selectYyReferralRewardById" parameterType="Long" resultMap="YyReferralRewardResult">
        <include refid="selectYyReferralRewardListVo"/>
        where rr.id = #{id}
    </select>

    <insert id="insertYyReferralReward" useGeneratedKeys="true" keyProperty="id">
        insert into yy_referral_reward
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="referrerId != null">referrer_id,</if>
            <if test="referredId != null">referred_id,</if>
            <if test="referralDepth != null">referral_depth,</if>
            <if test="triggerType != null">trigger_type,</if>
            <if test="triggerAmount != null">trigger_amount,</if>
            <if test="rewardAmount != null">reward_amount,</if>
            <if test="calculatedBy != null">calculated_by,</if>
            <if test="status != null">status,</if>
            <if test="configId != null">config_id,</if>
            <if test="payOrderId != null">pay_order_id,</if>
            <if test="remark != null">remark,</if>
            create_time,
        </trim>
        <trim prefix="values(" suffix=")" suffixOverrides=",">
            <if test="referrerId != null">#{referrerId},</if>
            <if test="referredId != null">#{referredId},</if>
            <if test="referralDepth != null">#{referralDepth},</if>
            <if test="triggerType != null">#{triggerType},</if>
            <if test="triggerAmount != null">#{triggerAmount},</if>
            <if test="rewardAmount != null">#{rewardAmount},</if>
            <if test="calculatedBy != null">#{calculatedBy},</if>
            <if test="status != null">#{status},</if>
            <if test="configId != null">#{configId},</if>
            <if test="payOrderId != null">#{payOrderId},</if>
            <if test="remark != null">#{remark},</if>
            now(),
        </trim>
    </insert>

    <update id="updateYyReferralReward" parameterType="YyReferralReward">
        update yy_referral_reward
        <trim prefix="SET" suffixOverrides=",">
            <if test="referrerId != null">referrer_id = #{referrerId},</if>
            <if test="referredId != null">referred_id = #{referredId},</if>
            <if test="referralDepth != null">referral_depth = #{referralDepth},</if>
            <if test="triggerType != null">trigger_type = #{triggerType},</if>
            <if test="triggerAmount != null">trigger_amount = #{triggerAmount},</if>
            <if test="rewardAmount != null">reward_amount = #{rewardAmount},</if>
            <if test="calculatedBy != null">calculated_by = #{calculatedBy},</if>
            <if test="status != null">status = #{status},</if>
            <if test="configId != null">config_id = #{configId},</if>
            <if test="payOrderId != null">pay_order_id = #{payOrderId},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = now(),
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteYyReferralRewardById" parameterType="Long">
        delete from yy_referral_reward where id = #{id}
    </delete>

    <delete id="deleteYyReferralRewardByIds" parameterType="Long">
        delete from yy_referral_reward where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- 幂等检查：同一订单 + 同推荐人 + 同深度 -->
    <select id="countDuplicateReward" resultType="int">
        select count(*) from yy_referral_reward
        where referrer_id = #{referrerId}
          and referred_id = #{referredId}
          and referral_depth = #{depth}
          and pay_order_id = #{payOrderId}
    </select>
</mapper>
